    // Handmade Hero
    {
      "name": "Handmade Hero - Debug Dev (X11)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/games/handmade-hero-game/build/game",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/games/handmade-hero-game",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        { "text": "-enable-pretty-printing" },
        { "text": "handle SIGFPE stop print" },
        { "text": "set breakpoint pending on" }
      ],
      "preLaunchTask": "Handmade Hero - Build Dev (X11)",
