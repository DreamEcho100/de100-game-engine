{
  "version": "2.0.0",
  "tasks": [
    // Handmade Hero
    {
      "label": "Handmade Hero - Build Dev (X11)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=x11"],
      "options": {
        "cwd": "${workspaceFolder}/games/handmade-hero-game"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Handmade Hero - Build Dev (Raylib)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=raylib"],
      "options": {
        "cwd": "${workspaceFolder}/games/handmade-hero-game"
      },
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Handmade Hero - Build Dev - Game Only (X11)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=x11", "--build-game"],
      "options": {
        "cwd": "${workspaceFolder}/games/handmade-hero-game"
      },
      "group": "build",
      "problemMatcher": ["$gcc"]
    },

    //
    // Tetris
    //
    {
      "label": "Tetris - Build/Run (X11)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=x11"],
      "options": {
        "cwd": "${workspaceFolder}/games/tetris"
      },
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Tetris - Build/Run (Raylib)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=raylib"],
      "options": {
        "cwd": "${workspaceFolder}/games/tetris"
      },
      "group": "build",
      "problemMatcher": ["$gcc"]
    },

    //
    // Snake
    //
    {
      "label": "Snake - Build/Run (X11)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=x11"],
      "options": {
        "cwd": "${workspaceFolder}/games/snake"
      },
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Snake - Build/Run (Raylib)",
      "type": "shell",
      "command": "./build-dev.sh",
      "args": ["--backend=raylib"],
      "options": {
        "cwd": "${workspaceFolder}/games/snake"
      },
      "group": "build",
      "problemMatcher": ["$gcc"]
    }
  ]
}
